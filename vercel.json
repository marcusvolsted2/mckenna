{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/contact", "destination": "/kontakt", "permanent": true },
    { "source": "/contact.html", "destination": "/kontakt", "permanent": true },
    { "source": "/contact-us", "destination": "/kontakt", "permanent": true },
    { "source": "/kontakt-os", "destination": "/kontakt", "permanent": true },
    { "source": "/en/kontakt", "destination": "/en/contact", "permanent": true },
    { "source": "/en/kontakt-os", "destination": "/en/contact", "permanent": true },
    { "source": "/en/contact-us", "destination": "/en/contact", "permanent": true },
    { "source": "/websites", "destination": "/hjemmesider", "permanent": true }
  ],
  "rewrites": [
    { "source": "/en/google-ads", "destination": "/en/google-ads-seo.html" },
    { "source": "/en/poas", "destination": "/en/poas.html" },
    { "source": "/en/contact", "destination": "/kontakt.html" },
    { "source": "/en", "destination": "/en/index.html" },
    { "source": "/google-ads", "destination": "/google-ads-seo.html" },
    { "source": "/poas", "destination": "/poas.html" },
    { "source": "/hjemmesider", "destination": "/websites.html" },
    { "source": "/betingelser", "destination": "/conditions.html" },
    { "source": "/cookiepolitik", "destination": "/cookie-policy.html" },
    { "source": "/paid-social", "destination": "/paid-social.html" }
  ]
}
